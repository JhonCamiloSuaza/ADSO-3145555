@startuml Diagrama_Flujo_Cafetin

title Sistema de Pedidos del Cafetin

skinparam defaultFontSize 11
skinparam activityFontSize 11
skinparam ArrowFontSize 10
skinparam padding 3
skinparam roundCorner 8

skinparam activity {
    BackgroundColor #FFFACD
    BorderColor #FF8C00
    FontColor #333333
    BorderThickness 1
}

skinparam activityDiamond {
    BackgroundColor #E6F3FF
    BorderColor #4169E1
    FontSize 10
}

start

:Acceder al sistema;

:Mostrar productos;

if (Productos disponibles?) then (Si)

    :Seleccionar producto;

    :Agregar al carrito;

    while (Mas productos?) is (Si)
        :Seleccionar producto;
        :Agregar al carrito;
    endwhile (No)

    if (Quitar alguno?) then (Si)
        :Quitar del carrito;
    else (No)
    endif

    if (Carrito vacio?) then (Si)
        :Error: Sin productos;
        stop
    else (No)
    endif

    :Revisar carrito;

    if (Confirmar pedido?) then (Si)
        :Confirmar pedido;
        :Registrar pedido;
        :Ordenar por hora;
        :Bloquear modificaciones;
        :Pedido enviado;
        :Ver pedidos;
        :Atender en orden;
        :Preparar pedido;
        :Pedido completado;
    else (No)
        :Cancelar pedido;
        stop
    endif

else (No)
    :Sin stock;
    stop
endif

stop

@enduml