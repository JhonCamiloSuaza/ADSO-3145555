              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/libros/{{libro_id}}",
              "host": ["{{base_url}}"],
              "path": ["libros", "{{libro_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "🔄 Préstamos",
      "item": [
        {
          "name": "Crear Préstamo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('prestamo_id', jsonData.id);",
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Tiene estado ACTIVO', function () {",
                  "    pm.expect(jsonData.estado).to.eql('ACTIVO');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": { \"id\": \"{{usuario_id}}\" },\n  \"libro\": { \"id\": \"{{libro_id}}\" },\n  \"estado\": \"ACTIVO\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/prestamos",
              "host": ["{{base_url}}"],
              "path": ["prestamos"]
            }
          }
        },
        {
          "name": "Consultar Todos los Préstamos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Retorna array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/prestamos",
              "host": ["{{base_url}}"],
              "path": ["prestamos"]
            }
          }
        },
        {
          "name": "Consultar Préstamo por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Tiene usuario y libro', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.usuario).to.not.be.null;",
                  "    pm.expect(jsonData.libro).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/prestamos/{{prestamo_id}}",
              "host": ["{{base_url}}"],
              "path": ["prestamos", "{{prestamo_id}}"]
            }
          }
        },
        {
          "name": "Modificar Préstamo (Devolver libro)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Estado es DEVUELTO', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.estado).to.eql('DEVUELTO');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": { \"id\": \"{{usuario_id}}\" },\n  \"libro\": { \"id\": \"{{libro_id}}\" },\n  \"fechaPrestamo\": \"2026-04-01T10:00:00\",\n  \"fechaDevolucion\": \"2026-04-22T10:00:00\",\n  \"estado\": \"DEVUELTO\"\n}"
            },
