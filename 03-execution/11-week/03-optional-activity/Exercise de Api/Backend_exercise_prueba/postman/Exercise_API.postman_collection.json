            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"La Vorágine - Edición Especial\",\n  \"autor\": \"José Eustasio Rivera\",\n  \"isbn\": \"978-958-42-1234-5\",\n  \"genero\": \"Novela Clásica\",\n  \"fechaPublicacion\": \"1924-11-25\",\n  \"disponible\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/libros/{{libro_id}}",
