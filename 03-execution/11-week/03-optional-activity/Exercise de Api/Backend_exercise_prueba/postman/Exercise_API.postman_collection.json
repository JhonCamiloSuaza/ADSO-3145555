{
  "info": {
    "name": "Exercise API - Préstamos de Libros",
    "description": "Colección Postman para probar todos los endpoints CRUD de la API REST.\n\nEntidades:\n- Usuarios (entidad primaria)\n- Libros (entidad primaria)\n- Préstamos (entidad secundaria)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "usuario_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "libro_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "prestamo_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "👤 Usuarios",
      "item": [
        {
          "name": "Crear Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set('usuario_id', jsonData.id);",
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Tiene ID UUID', function () {",
                  "    pm.expect(jsonData.id).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan\",\n  \"apellido\": \"Pérez\",\n  \"email\": \"juan.perez@test.com\",\n  \"telefono\": \"+57 300 111 2222\",\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios",
              "host": ["{{base_url}}"],
              "path": ["usuarios"]
            }
          }
        },
        {
          "name": "Consultar Todos los Usuarios",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Retorna array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/usuarios",
              "host": ["{{base_url}}"],
              "path": ["usuarios"]
            }
          }
        },
        {
          "name": "Consultar Usuario por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Tiene nombre', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.nombre).to.not.be.null;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            }
          }
        },
        {
          "name": "Modificar Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Nombre actualizado', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.nombre).to.eql('Juan Carlos');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Juan Carlos\",\n  \"apellido\": \"Pérez Gómez\",\n  \"email\": \"juan.perez@test.com\",\n  \"telefono\": \"+57 300 999 8888\",\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            }
          }
        },
        {
          "name": "Eliminar Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204 No Content', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/usuarios/{{usuario_id}}",
              "host": ["{{base_url}}"],
              "path": ["usuarios", "{{usuario_id}}"]
            }
          }
        }
      ]
    },
    {
